{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "فجر الوادي",
  "version": "1.0.0",
  "identifier": "com.fajralwadi.cars",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "شركة فجر الوادي لتجارة السيارات",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "maximized": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "نظام إدارة المعرض والحسابات",
    "longDescription": "نظام إدارة الحسابات والسيارات لشركة فجر الوادي — يعمل محلياً بدون إنترنت"
  }
}
