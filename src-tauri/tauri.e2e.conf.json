{
  "$schema": "https://schema.tauri.app/config/2",
  "app": {
    "withGlobalTauri": true,
    "security": {
      "capabilities": [
        {
          "identifier": "e2e",
          "description": "صلاحيات تشغيل الاختبارات الفعلية فقط",
          "windows": ["main"],
          "permissions": [
            "core:default",
            "core:window:default",
            "wdio:default",
            "wdio-webdriver:default"
          ]
        }
      ]
    }
  },
  "bundle": {
    "active": false
  }
}
